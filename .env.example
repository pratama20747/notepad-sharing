# Connection string Neon Postgres kamu (dapat dilihat di dashboard Neon)
# Contoh: postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

JWT_SECRET=
PASSWORD_MIN_LENGTH=8
APP_ENV=development
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev
BASE_URL=
# Port server (opsional, default 8080)
PORT=8080
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
GOOGLE_FRONTEND_REDIRECT_URL=http://localhost:3000/dashboard
# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=https://media.binery.my.id

# Limit ukuran file (dalam MB) & jumlah attachment
MAX_AVATAR_SIZE_MB=5
MAX_IMAGE_ATTACHMENT_SIZE_MB=10
MAX_VIDEO_ATTACHMENT_SIZE_MB=50
MAX_ATTACHMENTS_PER_NOTE=10

# TTL presigned URL (menit)
PRESIGN_TTL_MINUTES=10
